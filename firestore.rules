rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the user has the admin custom claim
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Players: anyone can read, only admins can write
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Games: anyone can read, only admins can write
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tournaments: anyone can read, only admins can write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
